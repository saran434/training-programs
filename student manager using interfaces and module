package student

import (
	"encoding/json"
	"fmt"
	"os"
)

type Student struct {
	ID   int    `json:"id"`
	Name string `json:"name"`
}

type StudentService interface {
	AddStudent(id int, name string) error
	SearchStudent(id int) (*Student, error)
	ViewStudents() []Student
}

type StudentCatalogue struct {
	Students []Student
}

func (sc *StudentCatalogue) AddStudent(id int, name string) error {

	if name == "" {
		return fmt.Errorf("student name cannot be empty")
	}

	for _, s := range sc.Students {
		if s.ID == id {
			return fmt.Errorf("ID number already present")
		}
	}

	sc.Students = append(sc.Students, Student{
		ID:   id,
		Name: name,
	})

	return SaveStudents(sc.Students)
}

func (sc *StudentCatalogue) SearchStudent(id int) (*Student, error) {

	for i := range sc.Students {
		if sc.Students[i].ID == id {
			return &sc.Students[i], nil
		}
	}

	return nil, fmt.Errorf("student not found")
}

func (sc *StudentCatalogue) ViewStudents() []Student {
	return sc.Students
}

func LoadStudents() ([]Student, error) {

	var students []Student

	data, err := os.ReadFile("students.json")

	if err != nil {

		if os.IsNotExist(err) {
			return []Student{}, nil
		}

		return nil, err
	}

	err = json.Unmarshal(data, &students)

	if err != nil {
		return nil, err
	}

	return students, nil
}

func SaveStudents(students []Student) error {

	data, err := json.MarshalIndent(students, "", "  ")

	if err != nil {
		return err
	}

	return os.WriteFile("students.json", data, 0644)
}


