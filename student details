package main
import "fmt"
type Student struct {
	ID   int
	Name string
}
var studentList []Student
func addStudent() {
	var studentID int
	var studentName string

	fmt.Print("Enter Student ID: ")
	fmt.Scan(&studentID)

	fmt.Print("Enter Student Name: ")
	fmt.Scan(&studentName)

	newStudent := Student{
		ID:   studentID,
		Name: studentName,
	}

	studentList = append(studentList, newStudent)

	fmt.Println("Student added successfully!")
}
func listStudents() {
	if len(studentList) == 0 {
		fmt.Println("No students available.")
		return
	}

	fmt.Println("\nStudent List:")
	for _, student := range studentList {
		fmt.Println("ID:", student.ID, "Name:", student.Name)
	}
}
func searchStudent() {
	var searchID int

	fmt.Print("Enter Student ID to search: ")
	fmt.Scan(&searchID)

	for _, student := range studentList {
		if student.ID == searchID {
			fmt.Println("Student Found:")
			fmt.Println("ID:", student.ID)
			fmt.Println("Name:", student.Name)
			return
		}
	}

	fmt.Println("Student not found.")
}
func deleteStudent() {
	var deleteID int

	fmt.Print("Enter Student ID to delete: ")
	fmt.Scan(&deleteID)

	for index, student := range studentList {
		if student.ID == deleteID {
			studentList = append(studentList[:index], studentList[index+1:],studentList[index+2:]...)
			fmt.Println("Student deleted successfully!")
			return
		}
	}

	fmt.Println("Student not found.")
}

func main() {
	for {
		var choice int

		fmt.Println("1. Add Student")
		fmt.Println("2. List Students")
		fmt.Println("3. Search Student")
		fmt.Println("4. Delete Student")

		fmt.Print("Enter your choice: ")
		fmt.Scan(&choice)

		switch choice {

		case 1:
			addStudent()

		case 2:
			listStudents()

		case 3:
			searchStudent()

		case 4:
			deleteStudent()
			return

		default:
			fmt.Println("Invalid choice")
		}
	}
}
